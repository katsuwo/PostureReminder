<Window x:Class="PostureReminder.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PostureReminder - 設定"
        Width="450" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Interval -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="リマインド間隔 (分):" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

        <!-- Idle threshold -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="離席判定 (分):" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding IdleThresholdMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

        <!-- Reminder message -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="メッセージ:" VerticalAlignment="Top" Margin="0,0,10,10"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ReminderMessage, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,0,0,10"/>

        <!-- Toast -->
        <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="Toast通知を表示する"
                  IsChecked="{Binding ShowToast}" Margin="0,0,0,8"/>

        <!-- Sound -->
        <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="通知音を鳴らす"
                  IsChecked="{Binding PlaySound}" Margin="0,0,0,8"/>

        <!-- Custom sound -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="カスタム音声:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <DockPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Content="参照..." Command="{Binding BrowseSoundCommand}" Width="60" Margin="5,0,0,0"/>
            <TextBox Text="{Binding CustomSoundPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
        </DockPanel>

        <!-- Dialog -->
        <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Content="ダイアログを表示する"
                  IsChecked="{Binding ShowDialog}" Margin="0,0,0,8"/>

        <!-- Auto start -->
        <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Content="Windows起動時に自動起動する"
                  IsChecked="{Binding AutoStart}" Margin="0,0,0,8"/>

        <!-- Save button -->
        <Button Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                Content="保存" Command="{Binding SaveCommand}"
                Width="100" Height="35" HorizontalAlignment="Right"
                FontSize="14"/>
    </Grid>
</Window>
